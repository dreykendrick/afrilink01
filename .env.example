# AfriLink Marketplace Environment Variables

# Supabase (auto-configured by Lovable Cloud)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# Application URL
VITE_APP_URL=https://afrilink01.vercel.app

# Demo Mode - set to "true" for demo/testing without real payments
VITE_DEMO_MODE=false

# ===== Payment Provider Configuration =====
# Mode: STUB (testing without real provider) or LIVE (production with Briq/MeetPay)
PAYMENT_PROVIDER_MODE=STUB

# Platform fee percentage (applied to product subtotal only, delivery excluded)
PLATFORM_FEE_PERCENT=5

# Minimum withdrawal amount in TZS
MIN_WITHDRAWAL_TZS=20000

# Default currency
CURRENCY_DEFAULT=TZS

# ===== Briq/MeetPay Integration (required for LIVE mode) =====
# Base URL for Briq payment API
BRIQ_BASE_URL=https://paygrid.briq.tz

# API key from Briq developer dashboard (required for LIVE mode)
BRIQ_API_KEY=

# Developer App ID from Briq (optional, included in payment requests if set)
BRIQ_DEVELOPER_APP_ID=

# Webhook secret for verifying Briq webhook signatures (optional)
# If not set, webhooks still work via server-side verification
BRIQ_WEBHOOK_SECRET=

# ===== How to switch to LIVE mode =====
# 1. Set PAYMENT_PROVIDER_MODE=LIVE
# 2. Set BRIQ_API_KEY to your Briq API key
# 3. Set BRIQ_BASE_URL to the correct Briq endpoint
# 4. Optionally set BRIQ_DEVELOPER_APP_ID
# 5. Redeploy edge functions
#
# In LIVE mode:
# - Payment creation calls Briq API and redirects buyer to Briq checkout
# - Payment confirmation verifies status with Briq server-side before applying splits
# - Webhook endpoint also verifies with Briq before crediting wallets
# - Idempotency ensures no double-crediting even if webhook + return URL both fire
