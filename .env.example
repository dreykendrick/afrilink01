# AfriLink Marketplace Environment Variables

# Supabase (auto-configured by Lovable Cloud)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# Application URL
VITE_APP_URL=https://shop.afrilink.info

# Demo Mode - set to "true" for demo/testing without real payments
VITE_DEMO_MODE=false

# ===== Payment Provider Configuration =====
# Mode: STUB (testing) or LIVE (production)
PAYMENT_PROVIDER_MODE=STUB

# Platform fee percentage (applied to product subtotal only)
PLATFORM_FEE_PERCENT=5

# Minimum withdrawal amount in TZS
MIN_WITHDRAWAL_TZS=20000

# Default currency
CURRENCY_DEFAULT=TZS

# ===== Briq/MeetPay Integration (for LIVE mode) =====
# Get these from your Briq developer dashboard
BRIQ_BASE_URL=https://karibu.briq.tz/v1
BRIQ_API_KEY=
BRIQ_DEVELOPER_APP_ID=
BRIQ_WEBHOOK_SECRET=
